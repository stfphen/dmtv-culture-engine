# ---- Database (self-hosted Postgres on your VPS) ----
# Either set DATABASE_URL, or leave it empty to run in MOCK mode (in-memory, no DB needed).
DATABASE_URL=postgres://dmtv:dmtv@localhost:5432/dmtv_culture

# ---- AI providers (optional). If both empty, engine uses deterministic MOCK output. ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Which provider to prefer when keys exist: anthropic | openai | mock
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# ---- Optional adapters ----
YOUTUBE_API_KEY=

# ---- Security ----
# Required header (x-cron-secret) to trigger /api/run in production.
CRON_SECRET=change-me

# ---- Public app config ----
NEXT_PUBLIC_APP_NAME=DMTV Culture Engine

# ---- Visual content sourcing (all optional; engine degrades gracefully) ----
PEXELS_API_KEY=          # free: https://www.pexels.com/api/
UNSPLASH_ACCESS_KEY=     # free: https://unsplash.com/developers
IMAGE_MODEL=dall-e-3     # only used if OPENAI_API_KEY is set (AI-generated visuals)

# ---- AI image generation (Nano Banana / Gemini or OpenAI) ----
GEMINI_API_KEY=          # Google AI Studio: https://aistudio.google.com/apikey  (Gemini 2.5 Flash Image = "Nano Banana")
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_PROVIDER=          # blank=auto (prefers Gemini), or "gemini" / "openai"
