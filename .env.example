# ---- Database (self-hosted Postgres on your VPS) ----
# Either set DATABASE_URL, or leave it empty to run in MOCK mode (in-memory, no DB needed).
DATABASE_URL=postgres://dmtv:dmtv@localhost:5432/dmtv_culture

# ---- AI providers (optional). If both empty, engine uses deterministic MOCK output. ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Which provider to prefer when keys exist: anthropic | openai | mock
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# ---- Optional adapters ----
YOUTUBE_API_KEY=

# ---- Security ----
# Required header (x-cron-secret) to trigger /api/run in production.
CRON_SECRET=change-me

# ---- Public app config ----
NEXT_PUBLIC_APP_NAME=DMTV Culture Engine
